@page
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Redirecting...</title>
</head>
<body>
    <script src="~/js/core/role.js"></script>
    <script>
            // kiểm tra token và role, sau đó chuyển hướng đến trang phù hợp
            // nếu token không tồn tại hoặc role không hợp lệ thì xóa token và chuyển về trang customer
            (function () {
                const token = localStorage.getItem("accessToken");

                if (!token) {
                    window.location.href = "/customer";
                    return;
                }

                const role = (StoreApp.role.getRoleFromToken(token) || "").toLowerCase();

                if (role === "admin") {
                    window.location.href = "/admin";
                    return;
                }

                if (role === "staff") {
                    window.location.href = "/staff";
                    return;
                }

                if (role === "customer") {
                    window.location.href = "/customer";
                    return;
                }

                // token lỗi / role không hợp lệ
                localStorage.removeItem("accessToken");
                localStorage.removeItem("refreshToken");
                window.location.href = "/customer";
            })();
    </script>
</body>
</html>