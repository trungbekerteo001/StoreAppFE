@page "/route"
@{
    ViewData["Title"] = "Routing";
}
<p>Routing...</p>

@section Scripts {
    <!-- Khi trang load, nó gọi routeByRole() trong role.js -->
    <script>
        (async function () {
            await StoreApp.auth.restoreSessionIfNeeded();
            StoreApp.role.redirectByRole();
        })();
    </script>
}