@page "/admin/suppliers"
@{
    ViewData["Title"] = "Quản lý nhà cung cấp";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-suppliers.css" />
}

<div class="card">
    <div class="toolbar">
        <div class="toolbar-left">
            <h1 class="h1">Supplier</h1>
        </div>

        <div class="toolbar-right">
            <div class="search">
                <input id="kw" type="text" placeholder="Tìm theo tên / SĐT / email..." />
                <button class="btn" type="button" id="btnSupSearch">Tìm</button>
                <button class="btn" type="button" id="btnSupClear">Reset</button>
            </div>
            <button class="btn primary" type="button" id="btnSupOpenCreate">+ Thêm</button>
        </div>
    </div>

    <div id="supMsg" class="msg" style="margin-top:10px; display:none"></div>

    <div class="table-wrap" style="margin-top:12px">
        <table class="table" id="supTable">
            <thead>
                <tr>
                    <th style="width:70px">#</th>
                    <th style="min-width:180px">Tên NCC</th>
                    <th style="width:150px">SĐT</th>
                    <th style="min-width:200px">Email</th>
                    <th style="min-width:220px">Địa chỉ</th>
                    <th style="width:220px">Hành động</th>
                </tr>
            </thead>
            <tbody id="supTbody">
                <tr><td colspan="6" class="muted">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal" id="supModal" aria-hidden="true">
    <div class="modal-backdrop" id="supModalBackdrop"></div>

    <div class="modal-panel" role="dialog" aria-modal="true">
        <div class="modal-head">
            <div class="modal-title" id="supModalTitle">Thêm Supplier</div>
            <button class="iconbtn" type="button" id="btnSupCloseX" aria-label="Đóng">✕</button>
        </div>

        <div class="modal-body">
            <div class="form-grid">
                <label class="field">
                    <span>Tên NCC</span>
                    <input id="supName" type="text" placeholder="Ví dụ: Công ty ABC" />
                </label>

                <label class="field">
                    <span>SĐT</span>
                    <input id="supPhone" type="text" placeholder="Ví dụ: 098..." />
                </label>

                <label class="field">
                    <span>Email</span>
                    <input id="supEmail" type="text" placeholder="Ví dụ: abc@gmail.com" />
                </label>

                <label class="field field-full">
                    <span>Địa chỉ</span>
                    <input id="supAddress" type="text" placeholder="Ví dụ: Hà Nội" />
                </label>
            </div>

            <div id="supModalMsg" class="msg" style="margin-top:10px; display:none"></div>
        </div>

        <div class="modal-foot">
            <button class="btn" type="button" id="btnSupCancel">Hủy</button>
            <button class="btn primary" type="button" id="supSaveBtn">Lưu</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/admin/suppliers.js"></script>
}