@page "/admin/statistics"
@{
    ViewData["Title"] = "Thống kê";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-statistics.css" />
}

<div class="stat-page">
    <div class="stat-hero">
        <div>
            <h1>Thống kê quản trị</h1>
            <p>Thống kê doanh thu, tài chính, sản phẩm, đơn hàng và tồn kho.</p>
        </div>
    </div>

    <div class="stat-panel">
        <div class="stat-filter">
            <label>
                Từ ngày
                <input id="fromDate" type="date" />
            </label>

            <label>
                Đến ngày
                <input id="toDate" type="date" />
            </label>

            <label>
                Top bán chạy
                <input id="topInput" type="number" min="1" max="100" value="10" />
            </label>

            <label>
                Ngưỡng tồn kho
                <input id="thresholdInput" type="number" min="0" value="10" />
            </label>

            <button class="btn primary stat-load-btn" type="button" id="btnLoadStatistic">
                Xem thống kê
            </button>
        </div>

        <div class="stat-tabs">
            <button class="stat-tab active" data-stat="financial">Tài chính</button>
            <button class="stat-tab" data-stat="dailyRevenue">Doanh thu ngày</button>
            <button class="stat-tab" data-stat="bestSelling">Bán chạy</button>
            <button class="stat-tab" data-stat="orderStatus">Trạng thái đơn</button>
            <button class="stat-tab" data-stat="lowStock">Sắp hết hàng</button>
            <button class="stat-tab" data-stat="paymentMethod">Thanh toán</button>
            <button class="stat-tab" data-stat="categoryRevenue">Danh mục</button>
        </div>

        <div id="statMsg" class="msg" style="display:none"></div>

        <div id="summaryGrid" class="stat-summary-grid"></div>

        <div class="stat-table-card">
            <div class="stat-table-title">
                <div>
                    <h2 id="tableTitle">Thống kê tài chính</h2>
                    <p id="tableSubTitle">Doanh thu Order - Chi phí GRN = Thu nhập thật sự</p>
                </div>
            </div>

            <div class="stat-table-wrap">
                <table class="stat-table">
                    <thead id="statThead"></thead>
                    <tbody id="statTbody">
                        <tr>
                            <td class="empty-cell">Chọn loại thống kê để xem dữ liệu.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/admin/statistics.js"></script>
}