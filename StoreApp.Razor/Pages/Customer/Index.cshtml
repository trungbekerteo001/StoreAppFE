@page "/customer"
@{
    ViewData["Title"] = "Trang chủ khách hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer-home.css" asp-append-version="true" />
}

<div class="customer-home">
    <div class="customer-section">
        <div class="section-head">
            <div>
                <h2>Danh sách sản phẩm</h2>
                <div class="muted">Phân trang từ API Product</div>
            </div>

            <div class="product-toolbar customer-filter-panel">
                <input id="prdKeyword" type="text" placeholder="Tìm theo tên sản phẩm..." />

                <select id="cusCatFilter">
                    <option value="">Tất cả danh mục</option>
                </select>

                <select id="cusSupFilter">
                    <option value="">Tất cả nhà cung cấp</option>
                </select>

                <input id="cusMinPrice" type="number" step="1000" placeholder="Giá từ" />
                <input id="cusMaxPrice" type="number" step="1000" placeholder="Giá đến" />

                <input id="cusMinQuantity" type="number" step="1" placeholder="SL từ" />
                <input id="cusMaxQuantity" type="number" step="1" placeholder="SL đến" />

                <select id="cusSortBy">
                    <option value="CreatedAt">Ngày tạo</option>
                    <option value="ProductName">Tên sản phẩm</option>
                    <option value="Price">Giá</option>
                    <option value="Quantity">Số lượng</option>
                </select>

                <select id="cusIsDescending">
                    <option value="true">Giảm dần</option>
                    <option value="false">Tăng dần</option>
                </select>

                <button class="btn-primary small" type="button" id="btnCusSearch">Tìm</button>
                <button class="btn-secondary small" type="button" id="btnCusClear">Xóa lọc</button>
            </div>
        </div>

        <div id="cusMsg" class="msg" style="display:none"></div>

        <div id="productGrid" class="product-grid">
            <div class="empty-box">Đang tải sản phẩm...</div>
        </div>

        <div class="pager" id="pager" style="display:none">
            <button class="pager-btn" type="button" id="btnPrev">← Trước</button>
            <div class="pager-info" id="pagerInfo">Trang 1 / 1</div>
            <button class="pager-btn" type="button" id="btnNext">Sau →</button>
        </div>
    </div>
</div>

<div class="modal" id="productDetailModal" aria-hidden="true">
    <div class="modal-backdrop" id="cusDetailBackdrop"></div>

    <div class="modal-panel product-detail-modal" role="dialog" aria-modal="true">
        <div class="modal-head">
            <div class="modal-title">Chi tiết sản phẩm</div>
            <button class="iconbtn" type="button" id="btnCusCloseDetailX">✕</button>
        </div>

        <div class="modal-body">
            <div id="productDetailBody">
                <div class="empty-box">Đang tải chi tiết...</div>
            </div>

            <div id="detailMsg" class="msg" style="display:none; margin-top:10px"></div>
        </div>

        <div class="modal-foot">
            <button class="btn-secondary small" type="button" id="btnCusCloseDetail">Đóng</button>
            <button class="btn-primary small" type="button" id="btnAddToCart">Thêm vào giỏ hàng</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/customer/home.js" asp-append-version="true"></script>
}