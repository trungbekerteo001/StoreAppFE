@page "/customer/cart"
@{
    ViewData["Title"] = "Giỏ hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer-cart.css" asp-append-version="true" />
}

<div class="customer-cart-page">
    <div class="cart-layout">
        <div class="cart-main">
            <div class="cart-head">
                <div>
                    <h2>Giỏ hàng của bạn</h2>
                    <div class="muted">Sản phẩm được lưu ở localStorage</div>
                </div>

                <a class="btn-secondary small" href="/customer">← Tiếp tục mua hàng</a>
            </div>

            <div id="cartMsg" class="msg" style="display:none"></div>

            <div id="cartList">
                <div class="empty-box">Đang tải giỏ hàng...</div>
            </div>
        </div>

        <div class="cart-side">
            <div class="summary-card">
                <div class="summary-title">Tóm tắt đơn hàng</div>

                <div class="summary-row">
                    <span>Số loại sản phẩm</span>
                    <strong id="sumItemKinds">0</strong>
                </div>

                <div class="summary-row">
                    <span>Tổng số lượng</span>
                    <strong id="sumQuantity">0</strong>
                </div>

                <div class="summary-row total">
                    <span>Tổng tiền</span>
                    <strong id="sumAmount">0 đ</strong>
                </div>

                <button class="btn-secondary small summary-btn" type="button" id="btnCartClear">
                    Xóa toàn bộ giỏ hàng
                </button>

                <div class="order-form">
                    <label class="field-label" for="orderAddressId">Địa chỉ giao hàng</label>
                    <select id="orderAddressId" class="order-select">
                        <option value="">Đang tải địa chỉ...</option>
                    </select>
                    <a class="address-manage-link" href="/customer/addresses">+ Thêm / sửa địa chỉ giao hàng</a>

                    <label class="field-label" for="paymentMethod">Phương thức thanh toán</label>
                    <select id="paymentMethod" class="order-select">
                        <option value="">-- Chọn phương thức thanh toán --</option>
                        <option value="Cash">Tiền mặt</option>
                        <option value="VnPay">VNPay</option>
                    </select>
                </div>

                <button class="btn-primary small summary-btn" type="button" id="btnCreateOrder">
                    Xác nhận đặt hàng
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/customer/cart.js" asp-append-version="true"></script>
}