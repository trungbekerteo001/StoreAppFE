@page "/customer/orders"
@{
    ViewData["Title"] = "Lịch sử đặt hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer-orders.css" />
}

<div class="order-history-page">
    <div class="card history-card">
        <div class="history-head">
            <div>
                <h2>Lịch sử đặt hàng</h2>
                <div class="muted">Xem các đơn hàng bạn đã tạo</div>
            </div>

            <div class="history-actions">
                <a class="btn" href="/customer">← Tiếp tục mua hàng</a>
                <button class="btn" type="button" onclick="cusOrdReload()">Tải lại</button>
            </div>
        </div>

        <div id="cusOrdMsg" class="msg" style="display:none"></div>

        <div class="order-table-wrap">
            <table class="order-table">
                <thead>
                    <tr>
                        <th style="width:70px">#</th>
                        <th style="width:220px">Mã đơn</th>
                        <th style="width:160px">Thanh toán</th>
                        <th style="width:150px">Trạng thái</th>
                        <th style="width:100px">Số dòng</th>
                        <th style="width:160px">Tổng tiền</th>
                        <th style="width:180px">Cập nhật</th>
                        <th style="width:120px">Hành động</th>
                    </tr>
                </thead>
                <tbody id="cusOrdTbody">
                    <tr><td colspan="8" class="muted">Đang tải...</td></tr>
                </tbody>
            </table>
        </div>

        <div class="pager" id="cusOrdPager">
            <button class="btn" type="button" id="cusOrdPrevBtn" onclick="cusOrdPrevPage()">← Trước</button>
            <div class="pager-info" id="cusOrdPagerInfo">Trang 1 / 1</div>
            <button class="btn" type="button" id="cusOrdNextBtn" onclick="cusOrdNextPage()">Sau →</button>
        </div>
    </div>
</div>

<div class="modal" id="cusOrdModal" aria-hidden="true">
    <div class="modal-backdrop" onclick="cusOrdCloseModal()"></div>

    <div class="modal-panel" role="dialog" aria-modal="true">
        <div class="modal-head">
            <div>
                <div class="modal-title">Chi tiết đơn hàng</div>
                <div class="modal-sub">Thông tin đơn hàng của bạn</div>
            </div>
            <button class="iconbtn" type="button" onclick="cusOrdCloseModal()">✕</button>
        </div>

        <div class="modal-body">
            <div class="meta-grid">
                <div class="meta-box">
                    <div class="meta-label">Order Id</div>
                    <div class="meta-value mono" id="cusOrdViewId">-</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">Thanh toán</div>
                    <div class="meta-value" id="cusOrdViewPayment">-</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">Trạng thái</div>
                    <div class="meta-value" id="cusOrdViewStatus">-</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">Staff duyệt</div>
                    <div class="meta-value mono" id="cusOrdViewStaffId">-</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">Cập nhật</div>
                    <div class="meta-value" id="cusOrdViewUpdatedAt">-</div>
                </div>

                <div class="meta-box meta-box-full">
                    <div class="meta-label">Địa chỉ giao hàng</div>
                    <div class="meta-value" id="cusOrdViewAddress">-</div>
                </div>

                <div class="meta-box meta-box-full">
                    <div class="meta-label">Tổng tiền</div>
                    <div class="meta-value total-amount" id="cusOrdViewTotal">0 ₫</div>
                </div>
            </div>

            <div class="section-title">Sản phẩm trong đơn</div>

            <div class="order-table-wrap inner-table-wrap">
                <table class="order-table inner-table">
                    <thead>
                        <tr>
                            <th style="width:70px">#</th>
                            <th>Sản phẩm</th>
                            <th style="width:110px">Số lượng</th>
                            <th style="width:150px">Đơn giá</th>
                            <th style="width:160px">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody id="cusOrdItemsTbody">
                        <tr><td colspan="5" class="muted">Không có dữ liệu.</td></tr>
                    </tbody>
                </table>
            </div>

            <div id="cusOrdModalMsg" class="msg" style="display:none; margin-top:12px"></div>
        </div>

        <div class="modal-foot">
            <button class="btn" type="button" onclick="cusOrdCloseModal()">Đóng</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/customer.orders.js"></script>
    <script>
        authGuard(["Customer"]);
    </script>
}