@page "/customer/orders"
@{
    ViewData["Title"] = "Lịch sử đặt hàng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer-orders.css" asp-append-version="true" />
}

<div class="customer-orders-page">
    <div class="page-head">
        <div>
            <h2>Lịch sử đặt hàng</h2>
            <div class="muted">Xem đơn hàng đã đặt, trạng thái và chi tiết từng đơn.</div>
        </div>

        <a class="btn-secondary small" href="/customer">← Quay lại mua hàng</a>
    </div>

    <div id="cusOrdMsg" class="msg" style="display:none"></div>

    <div class="table-wrap" style="margin-top:12px">
        <table class="table" id="cusOrdTable">
            <thead>
                <tr>
                    <th style="width:72px">#</th>
                    <th style="width:220px">Mã đơn</th>
                    <th style="width:130px">Thanh toán</th>
                    <th style="width:140px">Trạng thái</th>
                    <th style="width:100px">Số dòng</th>
                    <th style="width:150px">Tổng tiền</th>
                    <th style="width:180px">Cập nhật</th>
                    <th style="width:260px">Hành động</th>
                </tr>
            </thead>
            <tbody id="cusOrdTbody">
                <tr><td colspan="8" class="muted">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>

    <div class="pager" id="cusOrdPager">
        <button class="pager-btn" type="button" id="cusOrdPrevBtn">← Trước</button>
        <div class="pager-info" id="cusOrdPagerInfo">Trang 1 / 1</div>
        <button class="pager-btn" type="button" id="cusOrdNextBtn">Sau →</button>
    </div>
</div>

<div class="modal" id="cusOrdModal" aria-hidden="true">
    <div class="modal-backdrop" id="cusOrdBackdrop"></div>

    <div class="modal-panel order-detail-modal" role="dialog" aria-modal="true">
        <div class="modal-head">
            <div>
                <div class="modal-title">Chi tiết đơn hàng</div>
                <div class="modal-sub">Thông tin giao hàng, trạng thái và sản phẩm đã đặt</div>
            </div>
            <button class="iconbtn" type="button" id="btnCusOrdCloseX">✕</button>
        </div>

        <div class="modal-body">
            <div class="meta-grid">
                <div class="meta-box">
                    <div class="meta-label">Order Id</div>
                    <div class="meta-value mono" id="cusOrdViewId">-</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">Thanh toán</div>
                    <div class="meta-value" id="cusOrdViewPayment">-</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">Trạng thái</div>
                    <div class="meta-value" id="cusOrdViewStatus">-</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">Cập nhật</div>
                    <div class="meta-value" id="cusOrdViewUpdatedAt">-</div>
                </div>

                <div class="meta-box meta-box-full">
                    <div class="meta-label">Địa chỉ giao hàng</div>
                    <div class="meta-value" id="cusOrdViewAddress">-</div>
                </div>

                <div class="meta-box meta-box-full">
                    <div class="meta-label">Tổng tiền</div>
                    <div class="meta-value total-amount" id="cusOrdViewTotal">0 đ</div>
                </div>
            </div>

            <div class="section-title">Chi tiết sản phẩm</div>

            <div class="table-wrap inner-table-wrap">
                <table class="table inner-table">
                    <thead>
                        <tr>
                            <th style="width:70px">#</th>
                            <th>Sản phẩm</th>
                            <th style="width:110px">Số lượng</th>
                            <th style="width:150px">Đơn giá</th>
                            <th style="width:160px">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody id="cusOrdItemsTbody">
                        <tr><td colspan="5" class="muted">Không có dữ liệu.</td></tr>
                    </tbody>
                </table>
            </div>

            <div id="cusOrdModalMsg" class="msg" style="display:none; margin-top:12px"></div>
        </div>

        <div class="modal-foot">
            <button class="btn-secondary small" type="button" id="btnCusOrdClose">Đóng</button>
            <button class="btn-danger small" type="button" id="btnCusOrdCancel">Hủy đơn</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/customer/orders.js" asp-append-version="true"></script>
}